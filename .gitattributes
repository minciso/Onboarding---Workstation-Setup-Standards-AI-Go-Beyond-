# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Text files
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.xml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.conf text eol=lf
*.toml text eol=lf

# Python
*.py text eol=lf
*.pyw text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf
requirements.txt text eol=lf
setup.py text eol=lf
setup.cfg text eol=lf
pyproject.toml text eol=lf

# Bash/Shell scripts
*.sh text eol=lf
*.bash text eol=lf
.bashrc text eol=lf
.bash_profile text eol=lf

# Ansible
*.j2 text eol=lf
ansible.cfg text eol=lf
inventory text eol=lf
hosts text eol=lf

# Git
.gitignore text eol=lf
.gitattributes text eol=lf

# VS Code
.editorconfig text eol=lf
.vscode/* text eol=lf

# Binary files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.sqlite binary

# Documents
*.pdf binary
*.docx binary
*.xlsx binary
